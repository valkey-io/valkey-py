+AnyChannelT = TypeVar("AnyChannelT", bytes, str, memoryview)  # noqa: Y001
+
+class CommandsProtocol(Protocol):
+    connection_pool: AsyncConnectionPool[Any] | ConnectionPool
+    def execute_command(self, *args, **options): ...
